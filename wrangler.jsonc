{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "randall-automation-works",
  "main": "dist/server/index.js",
  "compatibility_date": "2026-05-15",
  "assets": {
    "binding": "ASSETS",
    "directory": "dist/client"
  },
  "observability": {
    "enabled": true
  },
  "keep_vars": true
}
